      "ambient.dli": { "unit": "mol/m2/d", "target": { "min": 20, "max": 30 }, "warning": { "min": 16, "max": 34 }, "alarm": { "min": 12, "max": 40 } },
      "substrate.t": { "unit": "C", "target": { "min": 20, "max": 24 }, "warning": { "min": 18, "max": 25 }, "alarm": { "min": 16, "max": 27 } },
      "fertigation.ec": { "unit": "mS/cm", "target": { "min": 1.2, "max": 2.0 }, "warning": { "min": 1.0, "max": 2.2 }, "alarm": { "min": 0.8, "max": 2.5 } },
      "fertigation.ph": { "unit": "pH", "target": { "min": 5.8, "max": 6.3 }, "warning": { "min": 5.6, "max": 6.5 }, "alarm": { "min": 5.4, "max": 6.7 } }
